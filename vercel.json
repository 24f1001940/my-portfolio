{
  "functions": {
    "server.js": {
      "runtime": "@vercel/node@3.2.10",
      "includeFiles": "{index.html,404.html,*.css,*.js,*.json,*.pdf,images/**,game/**}"
    },
    "api/**/*.js": {
      "runtime": "@vercel/node@3.2.10"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ]
}
